# ========================================
# AgentOS Environment Configuration
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider API Keys ---
OPENAI_API_KEY=your-openai-api-key-here          # Required for OpenAI models
ANTHROPIC_API_KEY=your-anthropic-api-key-here     # Optional: for Claude models
OLLAMA_BASE_URL=http://localhost:11434            # Optional: for local Ollama models

# --- Demo Mode ---
AGENTOS_DEMO_MODE=false                           # true to run without API keys (mock LLM + sample data)

# --- OpenTelemetry (optional) ---
OTEL_SERVICE_NAME=agentos                         # Service name in traces
OTEL_EXPORTER_OTLP_ENDPOINT=                      # e.g. http://localhost:4317 (gRPC) or :4318 (HTTP)
OTEL_EXPORTER_OTLP_PROTOCOL=grpc                  # grpc | http/protobuf

# --- Email (SMTP) — used by send_email tool ---
SMTP_HOST=                                          # e.g. smtp.gmail.com
SMTP_PORT=587                                       # 587 (STARTTLS) | 465 (SSL) | 25
SMTP_USER=                                          # SMTP login username
SMTP_PASSWORD=                                      # SMTP login password
SMTP_FROM=                                          # Sender address (defaults to SMTP_USER)

# --- Slack — used by slack_notify tool ---
SLACK_WEBHOOK_URL=                                  # Incoming Webhook URL

# --- Application Settings ---
AGENTOS_ENV=development                           # development | production
AGENTOS_LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
AGENTOS_LOG_FORMAT=json                           # json | text
AGENTOS_PORT=8000                                 # Web platform port
AGENTOS_SECRET_KEY=change-me-in-prod              # For auth/session signing
